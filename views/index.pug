extends layout

block content
  .app-container
    //- Sidebar Control Panel
    aside.sidebar
      .sidebar-header
        div(style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;")
          div
            h2 WCB Manitoba
            p Backend Data Previewer
          button.close-sidebar-btn(onclick="toggleSidebar()" title="Collapse Sidebar") &times;

      //- Document Switcher
      .control-group
        label.control-label Select WCB Form
        .tab-buttons
          a#btn-doc-medical.tab-button(href=`?doc=medical&dataset=${dataset}` class=(doc === 'medical' ? 'active' : '')) 1. Medical & Travel
          a#btn-doc-worker.tab-button(href=`?doc=worker&dataset=${dataset}` class=(doc === 'worker' ? 'active' : '')) 2. Worker Progress

      //- Dataset Switcher
      .control-group
        label.control-label Active Backend Dataset
        .preset-buttons
          a#preset-ds1.preset-button(href=`?doc=${doc}&dataset=1` class=(dataset === '1' ? 'active' : '')) Dataset 1 (Normal)
          a#preset-ds2.preset-button(href=`?doc=${doc}&dataset=2` class=(dataset === '2' ? 'active' : '')) Dataset 2 (Overflow)

      //- Primary Actions
      .sidebar-actions
        button#btn-print.btn-primary(onclick="window.print()")
          svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
            polyline(points="6 9 6 2 18 2 18 9")
            path(d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2")
            rect(x="6" y="14" width="12" height="8")
          | Print & Export to PDF

      //- Data Information Panel (Read-only description)
      .form-editor-container
        h3 Active Record Info
        div(style="font-size: 13px; line-height: 1.5; color: var(--text-muted); display: flex; flex-direction: column; gap: 10px;")
          p
            strong Form Type: 
            span(style="color: var(--text-light)")= (doc === 'medical') ? 'Medical & Travel Expense' : 'Worker Progress Report'
          p
            strong Loaded Dataset: 
            span(style="color: var(--text-light)")= (dataset === '1') ? 'Dataset 1 (Standard claims/updates)' : 'Dataset 2 (Large lists/overflowing text blocks)'
          p
            strong Worker Name: 
            span(style="color: var(--text-light)")= data.workerName
          p
            strong Claim Number: 
            span(style="color: var(--text-light)")= data.claimNo
          hr(style="border-color: var(--border-color); margin: 10px 0;")
          p(style="font-size: 11.5px; font-style: italic;") 
            | Note: User inputs are disabled on screen. Data is simulated as coming directly from the WCB database. Use the links above to switch views.

    //- Document Preview Panel
    main.preview-area
      .preview-header
        div.status-indicator
          button#btn-toggle-sidebar.toggle-sidebar-btn(onclick="toggleSidebar()" title="Toggle Sidebar")
            svg(width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
              line(x1="3" y1="12" x2="21" y2="12")
              line(x1="3" y1="6" x2="21" y2="6")
              line(x1="3" y1="18" x2="21" y2="18")
          span.pulse-dot
          | Live A4 Print Preview
        #page-count-badge.page-count-badge Pages: 0

      //- Visible Document Viewer (paginated by client JS)
      #document-viewer.document-viewer

      //- Hidden raw server-rendered Pug output, to be processed by client-side JS
      #hidden-raw-source(style="display: none;")
        if doc === 'medical'
          include medical.pug
        else if doc === 'worker'
          include worker.pug
